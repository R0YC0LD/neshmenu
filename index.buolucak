// ═══ PRICE FORMATTER ═══════════════════════════
function fmt(p){ return p.toLocaleString('tr-TR',{minimumFractionDigits:2,maximumFractionDigits:2})+'₺'; }

// ═══ RENDER PRODUCT CARD ═══════════════════════
function cardHTML(item){
  const name  = lang==='tr'?item.tr:item.en;
  const desc  = lang==='tr'?item.dtr:item.den;
  const imgSrc= item.img ? API+item.img : null;

  let imgBlock;
  if(imgSrc){
    imgBlock = `<div class="prod-img">
      <img src="${imgSrc}" alt="${name}" loading="lazy" decoding="async">
      ${item.isNew?'<span class="badge-new">YENİ</span>':''}
    </div>`;
  } else {
    imgBlock = `<div class="prod-img-none">NESH${item.isNew?'<span class="badge-new" style="position:absolute;top:10px;left:10px;">YENİ</span>':''}</div>`;
  }

  const descBlock = desc ? `<div class="prod-desc">${desc}</div>` : '';

  return `
  <div class="prod-card">
    ${imgBlock}
    <div class="prod-info">
      <div class="prod-header">
        <div class="prod-name">${name}</div>
        <div class="prod-price">${fmt(item.price)}</div>
      </div>
      ${descBlock}
    </div>
  </div>`;
}

// ═══ OPEN CATEGORY ══════════════════════════════
function openCat(key){
  const cat = CATS[key];
  if(!cat) return;
  document.getElementById('ovTitle').textContent = lang==='tr'?cat.tr:cat.en;

  const list = document.getElementById('prodList');

  if(cat.sub){
    list.innerHTML = cat.sub.map(sub=>{
      const label = lang==='tr'?sub.tr:sub.en;
      return `<div class="sub-cat-label">${label}</div>`
             + sub.items.map(cardHTML).join('');
    }).join('');
  } else {
    list.innerHTML = cat.items.map(cardHTML).join('');
  }

  const ov = document.getElementById('prodOv');
  ov.classList.add('open');
  ov.querySelector('.ov-body').scrollTop=0;
  document.body.style.overflow='hidden';
}

function closeOv(){
  // Geri tuşuna basmış gibi history'yi tetikle (popstate çalışacak)
  if (window.location.hash) {
    history.back();
  } else {
    // Yedek kapatma
    const ov = document.getElementById('prodOv');
    ov.classList.remove('open');
    document.body.style.overflow='';
  }
}

// ═══ LANGUAGE ══════════════════════════════════
function setLang(l){
  lang=l;
  // Dili HTML etiketine işleyerek CSS'te görünümleri yönetiyoruz
  document.documentElement.lang = l;
  
  // Buton aktif durumları
  document.getElementById('btnTr').classList.toggle('active',l==='tr');
  document.getElementById('btnEn').classList.toggle('active',l==='en');
  
  // Eğer ürün listesi açıksa, yeniden render yap
  const ov=document.getElementById('prodOv');
  if(ov.classList.contains('open')){
    const key=ov.dataset.key;
    if(key) openCat(key);
  }
}

// ═══ HISTORY & BACK BUTTON CONTROL ═════════════
// Sayfa açıldığında sahte bir geçmiş oluştur (siteden tamamen çıkmayı engeller)
window.addEventListener('load', function() {
  history.replaceState({ page: 'main' }, "", window.location.href);
  history.pushState({ page: 'main-active' }, "", window.location.href);
});

const origOpenCat = openCat;
window.openCat = function(key){
  document.getElementById('prodOv').dataset.key=key;
  // Menü açıldığında geçmişe ekle
  history.pushState({ modal: true }, "", "#" + key);
  origOpenCat(key);
};

window.addEventListener('popstate', function(event) {
  const overlay = document.getElementById('prodOv');

  // Ürün ekranı açıksa SADECE ONU KAPAT
  if (overlay.classList.contains('open')) {
    overlay.classList.remove('open');
    document.body.style.overflow='';
  } else {
    // Eğer ana menüdeyken fiziksel geri tuşuna basılırsa, siteden çıkışı engellemek için tekrar hapis state'ini it
    history.pushState({ page: 'main-active' }, "", window.location.href);
  }
});

// swipe right to close
let tx=0;
const ovElement=document.getElementById('prodOv');
ovElement.addEventListener('touchstart',e=>{tx=e.touches[0].clientX;},{passive:true});
ovElement.addEventListener('touchend',e=>{if(e.changedTouches[0].clientX-tx>70)closeOv();},{passive:true});

// prevent horizontal scroll on body
document.addEventListener('touchmove',function(e){
  if(e.touches.length>1) return;
},{passive:false});

// Başlangıç dilini ayarla
setLang('tr');
</script>
</body>
</html>
