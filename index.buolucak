<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="theme-color" content="#18181b">
<title>NESH Waffle · Burger · Coffee</title>
<link rel="icon" href="data:image/jpeg;base64," type="image/jpeg">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@300;400;500;600;700&family=Dancing+Script:wght@700&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
html{background:#18181b;overflow-x:hidden;}
body{
  font-family:'Outfit',sans-serif;
  background:#18181b;
  color:#fff;
  min-height:100vh;
  max-width:576px;
  margin:0 auto;
  -webkit-font-smoothing:antialiased;
  overflow-x:hidden;
  position:relative;
}

/* ══════════ HEADER ══════════ */
header{
  position:sticky;top:0;z-index:300;
  background:#27272a;
  display:grid;grid-template-columns:40px 1fr 60px;
  align-items:center;
  padding:8px 16px;
  min-height:54px;
  border-bottom:1px solid #3f3f46;
}
.chat-btn{
  width:34px;height:34px;border-radius:50%;
  border:1.5px solid rgba(255,255,255,.3);
  background:transparent;cursor:pointer;
  display:flex;align-items:center;justify-content:center;
  flex-shrink:0;
}
.chat-btn svg{width:16px;height:16px;fill:none;stroke:#fff;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;}
.logo-wrap{text-align:center;line-height:1;}
.logo-wrap .logo-main{
  font-family:'Bebas Neue',sans-serif;
  font-size:1.75rem;letter-spacing:7px;color:#fff;display:block;padding-right:5px;
}
.logo-wrap .logo-sub{
  font-size:.42rem;letter-spacing:3px;color:rgba(255,255,255,.4);
  text-transform:uppercase;display:block;margin-top:1px;
}
.lang-toggle{
  display:flex;justify-content:flex-end;
  border:1px solid #3f3f46;overflow:hidden;
}
.lang-btn{
  background:transparent;border:none;color:#71717a;
  width:32px;height:32px;
  font-family:'Outfit',sans-serif;
  font-size:.75rem;font-weight:600;cursor:pointer;transition:all .15s;
}
.lang-btn.active{background:#fff;color:#000;}
.lang-btn:not(:last-child){border-right:1px solid #3f3f46;}

/* ══════════ MAIN — category cards ══════════ */
#mainPage{
  padding:16px 12px 60px;
  display:flex;flex-direction:column;gap:12px;
}

.cat-card{
  position:relative;border-radius:14px;overflow:hidden;
  cursor:pointer;display:block;
  aspect-ratio:1/1;
  background:#27272a;
  -webkit-user-select:none;user-select:none;
}
.cat-card:active{transform:scale(.985);}
.card-bg{
  position:absolute;inset:0;
  background-size:cover;background-position:center;
  transition:transform .5s;
}
.cat-card:hover .card-bg{transform:scale(1.04);}
.card-ov{
  position:absolute;inset:0;
  background:rgba(0,0,0,.70);
}
.card-inner{
  position:absolute;inset:0;
  display:flex;flex-direction:column;
  align-items:center;justify-content:center;
  gap:6px;padding:20px;
  text-align:center;
}
.card-title-main{
  font-family:'Outfit',sans-serif;
  font-size:1.45rem;font-weight:700;
  color:#fff;letter-spacing:.5px;
  text-shadow:0 2px 8px rgba(0,0,0,.8);
}
.card-title-sub{
  font-size:.78rem;color:rgba(255,255,255,.65);
  font-weight:400;
  text-shadow:0 1px 4px rgba(0,0,0,.9);
  max-width:240px;line-height:1.4;
}
.card-script{
  font-family:'Dancing Script',cursive;
  font-size:2.4rem;color:#fff;
  text-shadow:0 2px 12px rgba(0,0,0,.6);
  line-height:1.1;
}

/* category images */
.bg-tost   {background-image:url('https://api.nesh.cafe/api/v1/public/data/uploads/pi_17575006133929693.png');}
.bg-waffle {background-image:url('https://api.nesh.cafe/api/v1/public/data/uploads/pi_17575016520501883.png');}
.bg-cup    {background-image:url('https://api.nesh.cafe/api/v1/public/data/uploads/pi_17655590707262699.jpeg');}
.bg-mojito  {background-image:url('https://images.unsplash.com/photo-1546171753-97d7676e4602?w=600&q=80');}
.bg-kokteyl {background-image:url('https://images.unsplash.com/photo-1514362545857-3bc16c4c7d1b?w=600&q=80');}
.bg-frappe  {background-image:url('https://images.unsplash.com/photo-1572490122747-3e9197aa1e7a?w=600&q=80');}
.bg-lemon   {background-image:url('https://images.unsplash.com/photo-1621263764928-df1444c5e859?w=600&q=80');}
.bg-frozen  {background-image:url('https://images.unsplash.com/photo-1437716606133-d2ef0d4e3063?w=600&q=80');}
.bg-soguk  {background-image:url('https://api.nesh.cafe/api/v1/public/data/uploads/pi_17575030785539384.png');}
.bg-sicak  {background-image:url('https://api.nesh.cafe/api/v1/public/data/uploads/pi_17575066501248478.png');}

/* ══════════ PRODUCT OVERLAY ══════════ */
.ov{
  display:none;position:fixed;inset:0;z-index:500;
  background:#18181b;flex-direction:column;overflow:hidden;
  max-width:576px;margin:0 auto;
  left:50%;transform:translateX(-50%);
  width:100%;
}
.ov.open{display:flex;}

.ov-head{
  display:flex;align-items:center;gap:10px;
  padding:0 14px;height:54px;
  background:#27272a;border-bottom:1px solid #3f3f46;flex-shrink:0;
}
.back-btn{
  background:none;border:none;color:#fff;cursor:pointer;
  display:flex;align-items:center;gap:3px;
  font-family:'Outfit',sans-serif;font-size:.75rem;
  font-weight:600;letter-spacing:1px;opacity:.7;padding:8px 0;
}
.back-btn:hover{opacity:1;}
.back-btn svg{width:22px;height:22px;stroke:#fff;fill:none;stroke-width:2.5;stroke-linecap:round;}
.ov-cat-name{font-family:'Outfit',sans-serif;font-size:1rem;font-weight:700;letter-spacing:.5px;}

.ov-body{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;overscroll-behavior:contain;}

/* sub-category label */
.sub-cat-label{
  padding:18px 14px 8px;
  font-size:.7rem;font-weight:700;letter-spacing:2px;
  text-transform:uppercase;color:#71717a;
  border-bottom:1px solid #27272a;
}

/* ══════════ PRODUCT CARD ══════════ */
.prod-list{
  padding:10px 10px 60px;
  display:flex;flex-direction:column;gap:10px;
}

.prod-card{
  background:#27272a;
  border-radius:14px;overflow:hidden;
  border:1px solid #3f3f46;
}

/* TOP: image area */
.prod-img{
  width:100%;
  aspect-ratio:16/10;
  overflow:hidden;background:#111;position:relative;
}
.prod-img img{
  width:100%;height:100%;object-fit:cover;display:block;
  transition:transform .4s;
}
.prod-card:hover .prod-img img{transform:scale(1.04);}

/* no image placeholder — NESH */
.prod-img-none{
  width:100%;aspect-ratio:16/10;
  background:#27272a;
  display:flex;align-items:center;justify-content:center;
  font-family:'Bebas Neue',sans-serif;font-size:2rem;letter-spacing:6px;
  color:rgba(255,255,255,.1);
  position:relative;
}

/* NEW badge */
.badge-new{
  position:absolute;top:10px;left:10px;
  background:#e5165d;color:#fff;
  font-size:.6rem;font-weight:700;letter-spacing:1.5px;
  padding:3px 8px;border-radius:20px;text-transform:uppercase;
}

/* BOTTOM: info */
.prod-info{padding:12px 14px 14px;}
.prod-header{
  display:flex;align-items:flex-start;
  justify-content:space-between;gap:8px;
  margin-bottom:6px;
}
.prod-name{
  font-size:.95rem;font-weight:700;
  color:#fff;letter-spacing:.2px;line-height:1.3;
  font-family:'Outfit',sans-serif;
}
.prod-price{
  font-size:.95rem;font-weight:700;color:#fff;
  white-space:nowrap;flex-shrink:0;
  font-variant-numeric:tabular-nums;
}
.prod-desc{
  font-size:.75rem;color:#a1a1aa;
  line-height:1.55;font-weight:400;
}

/* ══════════ LANG ══════════ */
/* Dil seçimine göre görünümleri CSS ile kontrol ediyoruz */
html[lang="tr"] .en-el { display: none !important; }
html[lang="en"] .tr-el { display: none !important; }
</style>
</head>
<body>

<header>
  <button class="chat-btn">
    <svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
  </button>
  <div class="logo-wrap">
    <span class="logo-main">NESH</span>
    <span class="logo-sub">WAFFLE · BURGER · COFFEE</span>
  </div>
  <div class="lang-toggle">
    <button class="lang-btn active" id="btnTr" onclick="setLang('tr')">TR</button>
    <button class="lang-btn" id="btnEn" onclick="setLang('en')">EN</button>
  </div>
</header>

<div id="mainPage">

  <div class="cat-card" onclick="openCat('tost')">
    <div class="card-bg bg-tost"></div><div class="card-ov"></div>
    <div class="card-inner">
      <div class="card-title-main tr-el">Tostlar</div>
      <div class="card-title-main en-el">Toasts</div>
    </div>
  </div>

  <div class="cat-card" onclick="openCat('waffle')">
    <div class="card-bg bg-waffle"></div><div class="card-ov"></div>
    <div class="card-inner">
      <div class="card-title-main">Nesh Waffle</div>
      <div class="card-title-sub tr-el">Lezzetli Waffle'larımız</div>
      <div class="card-title-sub en-el">Our delicious waffles</div>
    </div>
  </div>

  <div class="cat-card" onclick="openCat('cup')">
    <div class="card-bg bg-cup"></div><div class="card-ov"></div>
    <div class="card-inner">
      <div class="card-script tr-el">Nesh Cream Cup</div>
      <div class="card-script en-el">Nesh Cream Cups</div>
      <div class="card-title-sub tr-el">Nesh özel cup reçeteleri ile lezzet dolu kaşıklar sizi bekliyor.</div>
      <div class="card-title-sub en-el">Nesh special cup recipes and delicious spoons are waiting for you.</div>
    </div>
  </div>

  <div class="cat-card" onclick="openCat('mojito')">
    <div class="card-bg bg-mojito"></div><div class="card-ov"></div>
    <div class="card-inner">
      <div class="card-title-main tr-el">Mojito</div>
      <div class="card-title-main en-el">Mojito</div>
      <div class="card-title-sub tr-el">Ferahlatıcı mojito çeşitlerimiz</div>
      <div class="card-title-sub en-el">Refreshing mojito varieties</div>
    </div>
  </div>

  <div class="cat-card" onclick="openCat('kokteyl')">
    <div class="card-bg bg-kokteyl"></div><div class="card-ov"></div>
    <div class="card-inner">
      <div class="card-title-main tr-el">Kokteyller</div>
      <div class="card-title-main en-el">Cocktails</div>
      <div class="card-title-sub tr-el">Renkli ve özel kokteyl çeşitlerimiz</div>
      <div class="card-title-sub en-el">Colourful signature cocktails</div>
    </div>
  </div>

  <div class="cat-card" onclick="openCat('frappe')">
    <div class="card-bg bg-frappe"></div><div class="card-ov"></div>
    <div class="card-inner">
      <div class="card-title-main tr-el">Frappe</div>
      <div class="card-title-main en-el">Frappe</div>
      <div class="card-title-sub tr-el">Soğuk frappe çeşitlerimiz</div>
      <div class="card-title-sub en-el">Cold frappe varieties</div>
    </div>
  </div>

  <div class="cat-card" onclick="openCat('lemon')">
    <div class="card-bg bg-lemon"></div><div class="card-ov"></div>
    <div class="card-inner">
      <div class="card-title-main tr-el">Limonata</div>
      <div class="card-title-main en-el">Lemonade</div>
      <div class="card-title-sub tr-el">Taze limonata ve karışık içecekler</div>
      <div class="card-title-sub en-el">Fresh lemonades and mix drinks</div>
    </div>
  </div>

  <div class="cat-card" onclick="openCat('frozen')">
    <div class="card-bg bg-frozen"></div><div class="card-ov"></div>
    <div class="card-inner">
      <div class="card-title-main tr-el">Frozen İçecekler</div>
      <div class="card-title-main en-el">Frozen Drinks</div>
      <div class="card-title-sub tr-el">Buzlu ve serinletici içecekler</div>
      <div class="card-title-sub en-el">Icy cold frozen beverages</div>
    </div>
  </div>

  <div class="cat-card" onclick="openCat('soguk')">
    <div class="card-bg bg-soguk"></div><div class="card-ov"></div>
    <div class="card-inner">
      <div class="card-title-main tr-el">Soğuk İçecekler</div>
      <div class="card-title-main en-el">Cold Drinks</div>
    </div>
  </div>

  <div class="cat-card" onclick="openCat('sicak')">
    <div class="card-bg bg-sicak"></div><div class="card-ov"></div>
    <div class="card-inner">
      <div class="card-title-main tr-el">Sıcak İçecekler</div>
      <div class="card-title-main en-el">Hot Drinks</div>
    </div>
  </div>

</div><div class="ov" id="prodOv">
  <div class="ov-head">
    <button class="back-btn" onclick="closeOv()">
      <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
      <span class="tr-el">Geri</span><span class="en-el">Back</span>
    </button>
    <div class="ov-cat-name" id="ovTitle"></div>
  </div>
  <div class="ov-body">
    <div class="prod-list" id="prodList"></div>
  </div>
</div>

<script>
const API = 'https://api.nesh.cafe/api/v1/public/data/uploads/';
let lang = 'tr';

// ════════════════════════════════════════════════════════
// DATA — tam JSON verisi (İngilizce hatalar giderildi)
// ════════════════════════════════════════════════════════
const CATS = {

  tost:{
    tr:'Tostlar', en:'Toasts',
    items:[
      {img:'pi_17683887420917135.JPG', isNew:false,
       tr:'Kaşarlı Tost', en:'Cheese Toast',
       dtr:'Patates, cips sos ve dips sos ile servis edilir.',
       den:'Served with potato, chips sauce and dips sauce.', price:250},
      {img:'pi_17683880331296274.JPG', isNew:false,
       tr:'Sucuklu Tost', en:'Sausage Toast',
       dtr:'Patates, cips sos ve dips sos ile servis edilir.',
       den:'Served with potato, chips sauce and dips sauce.', price:280},
      {img:'pi_17683887999972533.JPG', isNew:false,
       tr:'Karışık Tost', en:'Mixed Toast',
       dtr:'Sucuk ve kaşarlı tostumuz; patates, cips sos ve dips sos ile servis edilir.',
       den:'Our sausage and cheddar toast; served with potatoes, chips sauce and dips sauce.', price:310},
    ]
  },

  waffle:{
    tr:'Nesh Waffle', en:'Nesh Waffle',
    items:[
      {img:'pi_17409882615105499.JPG', isNew:true,
       tr:'Nesh Pops Box', en:'Nesh Pops Box',
       dtr:'Özel hamurumuz, keyif veren çikolatalarımız ve taze meyvelerimiz ile arkadaşlarınız ile paylaşabileceğiniz bir mutluluk vaadediyoruz.',
       den:'We promise happiness that you can share with your friends with our special dough, delightful chocolates and fresh fruits.', price:950},
      {img:'pi_17383314552201644.jpg', isNew:false,
       tr:'Nesh Share Box', en:'Nesh Share Box',
       dtr:'Eşsiz reçetelerimiz ile yapılan sıcak hamurlarımızın kokusu eşliğinde gelen, taptaze günlük meyvelerimizi dalından yiyormuş hissine kapılacağınız; eşsiz katkısız ve SINIRSIZ çikolatalarımız ile arkadaşlarınızla bu mutluluğu paylaşmak iyi hissettirecek.',
       den:'Sharing this happiness with your friends will feel amazing, accompanied by the aroma of our warm dough made from unique recipes, the taste of fresh daily fruits, and our unique, additive-free, UNLIMITED chocolate.', price:950},
      {img:'pi_17351345235534705.jpeg', isNew:false,
       tr:'Special Waffle', en:'Special Waffle',
       dtr:'Sütlü çikolata, beyaz çikolata, çilek, muz, çikolata sos, fındık, toz fıstık ve hindistan cevizi.',
       den:'Milk chocolate, white chocolate, strawberry, banana, chocolate sauce, hazelnut, peanut powder, and coconut.', price:400},
      {img:'pi_17183569844674322.jpg', isNew:true,
       tr:'Nesh Waffle Cup', en:'Nesh Waffle Cup',
       dtr:'Benzersiz reçetemiz, eşsiz çikolatalarımız, taze meyvelerimiz ile birlikte; pratik, tadı damağınızda kalacak Cup waffle.',
       den:'A practical Cup waffle that will leave a lingering taste on your palate, featuring our unique recipe, exquisite chocolates, and fresh fruits.', price:275},
      {img:'pi_17183578385471251.jpg', isNew:true,
       tr:'Nesh TinyCakes', en:'Nesh TinyCakes',
       dtr:'Eşsiz reçetemiz ile 10 Adet mini pancake, benzersiz beyaz, sütlü, bueno ve çilekli çikolatalarımız; 2 adet süsleme, çilek ve muz ile birlikte servis edilir. (DIY)',
       den:'10 mini pancakes with our unique recipe, unique white, milk, bueno and strawberry chocolates; served with 2 decorations, strawberry and banana. (DIY)', price:400},
      {img:'pi_17407436386767050.JPG', isNew:false,
       tr:'Nesh Pops', en:'Nesh Pops',
       dtr:'8 adet waffle pops, içleri sütlü ve beyaz çikolata, üzerine sütlü beyaz çikolata sos ve krep kırığı, çilek, muz ile.<br>Ekstra isteyenler için 55₺',
       den:'8 waffle pops with milk and white chocolate inside, topped with milk and white chocolate sauce, crepe crumbles, strawberries, and bananas.<br>55₺ for extra.', price:380},
      {img:'pi_16993454042128283.jpg', isNew:false,
       tr:'Pops Cup', en:'Pops Cup',
       dtr:'4 adet waffle pops, içleri sütlü ve beyaz çikolata, üzerine sütlü beyaz çikolata sos ve krep kırığı, çilek, muz ile.',
       den:'4 waffle pops, with milk and white chocolate inside, with milk white chocolate sauce and crepe crumbles, strawberry, banana.', price:275},
      {img:'pi_16993455411287225.jpg', isNew:false,
       tr:'Double Waffle', en:'Double Waffle',
       dtr:'İki kat waffle hamuru arasına dilediğiniz içerikte hazırlanır.',
       den:'Prepared between two layers of waffle dough with your choice of ingredients.', price:500},
      {img:'pi_16993455589224563.jpg', isNew:false,
       tr:'Birthday Waffle', en:'Birthday Waffle',
       dtr:'Dört kat waffle hamuru arasına dilediğiniz içerikte hazırlanır.',
       den:'Prepared between four layers of waffle dough with your choice of ingredients.', price:750},
      {img:'pi_17407434169303505.JPG', isNew:false,
       tr:'Kids Waffle', en:'Kids Waffle',
       dtr:'Sütlü çikolata, çilek, muz ve çikolata sos akabinde renkli granül ile hazırlanır.',
       den:'Prepared with milk chocolate, strawberry, banana, chocolate sauce, and colorful sprinkles.', price:275},
      {img:'pi_17407437838321272.JPG', isNew:false,
       tr:'Çikolatalı Meyve Tabağı', en:'Chocolate Fruit Plate',
       dtr:'Çilek, kivi, muz ve mevsim meyveleri ile hazırlanır. Dileğiniz 2 çeşit çikolata eklenir.',
       den:'Prepared with strawberries, kiwi, bananas, and seasonal fruits. 2 types of chocolate of your choice are added.', price:425},
      {img:'pi_17407435690616057.JPG', isNew:false,
       tr:'Meyve Tabağı', en:'Fruit Plate',
       dtr:'Çilek, kivi, muz ve mevsim meyveleri ile hazırlanır.',
       den:'Prepared with strawberries, kiwi, bananas and seasonal fruits.', price:375},
      {img:'pi_17183564854988702.jpg', isNew:true,
       tr:'Nesh Kitkat Pops', en:'Nesh Kitkat Pops',
       dtr:'8 adet waffle pops, içleri sütlü ve beyaz çikolata, üzerine sütlü beyaz çikolata sos ve Kitkat kırığı, çilek, muz ile. Ekstra isteyenler için 55₺',
       den:'8 waffle pops, milk and white chocolate inside, milk and white chocolate sauce and Kitkat crumbs, strawberry, banana. Extra: 55₺', price:380},
      {img:'pi_17268430285817006.jpg', isNew:true,
       tr:'Kitkat Pops Cup', en:'Kitkat Pops Cup',
       dtr:'4 adet waffle pops, içleri sütlü ve beyaz çikolata, üzerine sütlü beyaz çikolata sos ve Kitkat kırığı, çilek, muz ile.',
       den:'4 waffle pops, milk and white chocolate inside, milk and white chocolate sauce and Kitkat crumbs, strawberry, banana.', price:275},
      {img:'pi_17183566904671810.jpg', isNew:true,
       tr:'Nesh Bueno Pops', en:'Nesh Bueno Pops',
       dtr:'8 adet waffle pops, içleri benzersiz BUENO çikolata, üzerine tamamlayıcı BUENO çikolata sos, çilek, muz ile. Ekstra isteyenlere 55₺',
       den:'8 waffle pops, unique BUENO chocolate inside, complementary BUENO chocolate sauce, strawberry, banana. Extra: 55₺', price:380},
      {img:'pi_17183566006329537.jpg', isNew:true,
       tr:'Bueno Pops Cup', en:'Bueno Pops Cup',
       dtr:'4 adet waffle pops, içleri benzersiz BUENO çikolatası, üzerine tamamlayıcı BUENO çikolata sosu, çilek, muz ile birlikte.',
       den:'4 waffle pops, unique BUENO chocolate inside, complementary BUENO chocolate sauce, with strawberry, banana.', price:275},
      {img:'pi_17183563538362185.jpg', isNew:true,
       tr:'Nesh Lotus Pops', en:'Nesh Lotus Pops',
